# 忽略“实验介绍”目录
实验介绍/

# 忽略 README.md 文件
README.md

# 忽略所有 PDF 文件
*.pdf

# 忽略“项目代码”目录下的所有 TXT 文件
项目代码/*.txt

# ----------------------------
# PyCharm 项目特定的忽略规则
# ----------------------------

# 忽略 PyCharm 项目配置目录
.idea/

# 忽略 Python 缓存目录
__pycache__/
*.py[cod]
*$py.class

# 忽略虚拟环境目录（如果您在项目内创建了虚拟环境）
venv/
env/
ENV/
.venv/
.env/

# 忽略 PyCharm 生成的日志文件
*.log

# 忽略操作系统生成的文件
.DS_Store
Thumbs.db